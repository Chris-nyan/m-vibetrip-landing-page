# ─────────────────────────────────────────────────────────────
# M-VibeTrip — environment configuration
# Copy this file to ".env" and fill in real values.
# Never commit your real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# Server
PORT=8080
NODE_ENV=development

# Public site URL (used in email links). No trailing slash.
SITE_URL=http://localhost:8080

# SQLite database file location (relative to project root or absolute)
DB_PATH=./data/mvibetrip.db

# ── Admin account ──────────────────────────────────────────────
# Used to seed the first admin user on initial DB creation.
ADMIN_USERNAME=admin
# Set a STRONG password before going live. Default below is only for first boot.
ADMIN_PASSWORD=mvibe2026
# Secret used to sign admin login tokens (JWT). Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
# How long an admin login stays valid
JWT_EXPIRES_IN=12h

# ── Lead notifications (optional) ──────────────────────────────
# If SMTP settings are present, every booking/quote/contact is emailed to NOTIFY_TO.
# Leave SMTP_HOST blank to disable email — leads are still saved to the database.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="M-VibeTrip <no-reply@m-vibetrip.com>"
NOTIFY_TO=info@m-vibetrip.com

# ── Business contact details (rendered into the site) ──────────
WHATSAPP_NUMBER=66980791316
CONTACT_EMAIL=info@m-vibetrip.com
PHONE_TH=+66 980 791 316
PHONE_MM=+95 925 041 1531

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for any.
CORS_ORIGIN=*
